# Revenue Edge — environment configuration
# Copy to .env and fill in. All services read from the same .env in dev.

# -----------------------------------------------------------------------------
# Supabase (NEW project, not shared with SMB-MetaPattern)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Retell AI (primary voice + SMS)
# -----------------------------------------------------------------------------
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
# Optional: default from-number if a channel config doesn't specify one
RETELL_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Twilio (only as fallback / STOP-HELP-START compliance; Retell bakes Twilio in)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
DEFAULT_EMAIL_FROM=no-reply@revenueedge.local

# -----------------------------------------------------------------------------
# LLM (single-provider for MVP; see docs/DEFERRED_MODEL_ROUTER.md for upgrade path)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Default chat model for conversation_intelligence_worker
LLM_CHAT_MODEL=gpt-4.1-mini
# Embeddings for knowledge_items
LLM_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Internal service-to-service auth
# Used by re-webhooks → re-api and re-workers → re-api
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_KEY=
# Fallback user id for workers making audited writes; must be a real auth.users row
INTERNAL_TOOL_USER_ID=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
ENVIRONMENT=development
RELEASE=local
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability (optional in dev)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DEV_ENABLED=false

# -----------------------------------------------------------------------------
# Worker tunables
# -----------------------------------------------------------------------------
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_CLAIM_BATCH_SIZE=5
WORKER_LOCK_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Service URLs (inside docker-compose, these are service names)
# -----------------------------------------------------------------------------
RE_API_URL=http://re-api:8080
RE_WEBHOOKS_URL=http://re-webhooks:8081
